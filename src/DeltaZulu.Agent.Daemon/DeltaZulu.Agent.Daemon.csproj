<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFrameworks>net10.0;net10.0-windows</TargetFrameworks>
    <AssemblyName>dzagentd</AssemblyName>
    <RootNamespace>DeltaZulu.Agent.Daemon</RootNamespace>
    <StartupObject>DeltaZulu.Agent.Daemon.Program</StartupObject>
  </PropertyGroup>
  <ItemGroup>
    <PackageReference Include="Microsoft.Extensions.Hosting" Version="10.0.0" />
    <PackageReference Include="Microsoft.Extensions.Hosting.Systemd" Version="10.0.0" />
    <PackageReference Include="Microsoft.Extensions.Hosting.WindowsServices" Version="10.0.0" />
  </ItemGroup>

  <ItemGroup>
    <Content Include="..\..\config\dzagentd.yaml" Link="config\dzagentd.yaml" CopyToOutputDirectory="PreserveNewest" />
  </ItemGroup>
  <ItemGroup>
    <ProjectReference Include="..\DeltaZulu.Agent.Application\DeltaZulu.Agent.Application.csproj" />
    <ProjectReference Include="..\DeltaZulu.Agent.Forwarder\DeltaZulu.Agent.Forwarder.csproj" />
    <ProjectReference Include="..\DeltaZulu.Agent.Inputs.Auditd\DeltaZulu.Agent.Inputs.Auditd.csproj" />
    <ProjectReference Include="..\DeltaZulu.Agent.Inputs.Files\DeltaZulu.Agent.Inputs.Files.csproj" />
    <ProjectReference Include="..\DeltaZulu.Agent.Inputs.Syslog\DeltaZulu.Agent.Inputs.Syslog.csproj" />
    <ProjectReference Include="..\DeltaZulu.Agent.Kql\DeltaZulu.Agent.Kql.csproj" />
    <ProjectReference Include="..\DeltaZulu.Agent.Outputs.Ndjson\DeltaZulu.Agent.Outputs.Ndjson.csproj" />
    <ProjectReference Include="..\DeltaZulu.Agent.Profiles\DeltaZulu.Agent.Profiles.csproj" />
  </ItemGroup>
  <ItemGroup Condition="$([MSBuild]::GetTargetPlatformIdentifier('$(TargetFramework)')) == 'windows'">
    <ProjectReference Include="..\DeltaZulu.Agent.Inputs.Windows\DeltaZulu.Agent.Inputs.Windows.csproj" />
  </ItemGroup>
</Project>
