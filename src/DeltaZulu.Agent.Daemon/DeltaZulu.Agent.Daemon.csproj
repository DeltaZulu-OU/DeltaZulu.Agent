<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFrameworks>net10.0;net10.0-windows</TargetFrameworks>
    <AssemblyName>dzagentd</AssemblyName>
    <RootNamespace>DeltaZulu.Agent.Daemon</RootNamespace>
    <StartupObject>DeltaZulu.Agent.Daemon.Program</StartupObject>
      <ApplicationManifest>app.manifest</ApplicationManifest>
  </PropertyGroup>
  <ItemGroup>
    <PackageReference Include="Microsoft.Extensions.Hosting" Version="10.0.0" />
    <PackageReference Include="Microsoft.Extensions.Hosting.Systemd" Version="10.0.0" />
    <PackageReference Include="Microsoft.Extensions.Hosting.WindowsServices" Version="10.0.0" />
  </ItemGroup>

  <ItemGroup>
    <Content Include="..\..\config\dzagentd.yaml" Link="config\dzagentd.yaml" CopyToOutputDirectory="PreserveNewest" />
    <Content Include="..\..\profiles\**\*" Link="profiles\%(RecursiveDir)%(Filename)%(Extension)" CopyToOutputDirectory="PreserveNewest" />
  </ItemGroup>
  <ItemGroup>
    <ProjectReference Include="..\DeltaZulu.Agent.Application\DeltaZulu.Agent.Application.csproj" />
    <ProjectReference Include="..\DeltaZulu.Agent.Outputs\DeltaZulu.Agent.Outputs.csproj" />
    <ProjectReference Include="..\DeltaZulu.Agent.Inputs\DeltaZulu.Agent.Inputs.csproj" />
    <ProjectReference Include="..\DeltaZulu.Agent.Kql\DeltaZulu.Agent.Kql.csproj" />
    <ProjectReference Include="..\DeltaZulu.Agent.Profiles\DeltaZulu.Agent.Profiles.csproj" />
    <ProjectReference Include="..\DeltaZulu.Agent.Shared\DeltaZulu.Agent.Shared.csproj" />
  </ItemGroup>
</Project>
